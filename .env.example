# Отдельный сервис прокси (порт по умолчанию 8787): npm run gigachat-proxy
# GIGACHAT_PROXY_PORT=8787
#
# Сборка/деплой фронта: запросы к GigaChat с браузера на внешний прокси (абсолютный базовый URL без / в конце).
# Пусто — использовать маршруты Next.js /api/gigachat/* на том же origin.
# На стороне прокси должны быть настроены CORS, если origin фронта другой.
# У cli-прокси: по умолчанию Access-Control-Allow-Origin: *; свой origin:
# GIGACHAT_CORS_ORIGIN=https://yourname.github.io
# GIGACHAT_PROXY_URL=https://your-proxy.example.com
# Дублирует URL в клиентский бандл (удобно для next build / Vercel):
# NEXT_PUBLIC_GIGACHAT_PROXY_URL=https://your-proxy.example.com

# Ключ: Base64(client_id:client_secret) из личного кабинета GigaChat API.
#GIGACHAT_AUTHORIZATION_KEY=

# Системные настройки GigaCHat
# GIGACHAT_MODEL=gigachat
# GIGACHAT_SYSTEM_PROMPT=Ты полезный ассистент. Отвечай кратко и по делу.

# При ошибке «self-signed certificate in certificate chain»:
# GIGACHAT_INSECURE_SSL=true
# Health: http://localhost:3000/api/gigachat/health (Next dev, без GIGACHAT_PROXY_URL)
# или http://127.0.0.1:8787/api/gigachat/health (напрямую на cli-прокси)
# с GIGACHAT_PROXY_URL: https://your-proxy.example.com/api/gigachat/health
#
# GitHub Actions (Pages): Repository variable GIGACHAT_PROXY_URL (или NEXT_PUBLIC_GIGACHAT_PROXY_URL — workflow подставляет обе).
# В сборку также пишется public/gigachat-proxy.json — fallback в браузере, если в бандле пусто.
# Локально имитировать Pages: положите public/gigachat-proxy.json с телом {"url":"https://ваш-прокси.example.com"}
# Локально проверить экспорт: BASE_PATH=/имя-репо npm run build:gh-pages (STATIC_EXPORT задаётся скриптом).

